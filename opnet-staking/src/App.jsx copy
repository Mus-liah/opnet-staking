  const [loading, setLoading] = useState(false);

  useEffect(() => {
    if (selected) setLockDays(selected.minLock);
  }, [selected]);

  const estRewards = selected && amount
    ? ((parseFloat(amount) * selected.apr) / 100 / 365 * lockDays).toFixed(4)
    : "—";

  const handleStake = () => {
    if (!selected || !amount || parseFloat(amount) <= 0) return;
    setLoading(true);
    setTimeout(() => {
      const pos = {
        id: Date.now(), validatorId: selected.id, validator: selected.name,
        staked: parseFloat(amount), apr: selected.apr, lockDays,
        startTs: Date.now(),
        unlockTs: Date.now() + lockDays * 86400 * 1000,
        rewards: 0, claimed: false,
      };
      onStaked(pos, fakeTxHash());
      setTx(fakeTxHash());
      setLoading(false);
      setAmount("");
    }, 1800);
  };

  return (
    <div style={{ background: "#0e0e0e", borderRadius: 10, border: "1px solid #1a1a1a", padding: "20px 24px" }}>
      <div style={{ fontSize: 13, fontWeight: 700, color: "#888", fontFamily: "monospace", marginBottom: 18 }}>STAKE</div>

      {!selected ? (
        <div style={{ color: "#333", fontFamily: "monospace", fontSize: 13, textAlign: "center", padding: "30px 0" }}>
          ← Select a validator first
        </div>
      ) : (
        <>
          <div style={{ marginBottom: 16 }}>
            <div style={{ fontSize: 11, color: "#555", fontFamily: "monospace", marginBottom: 6 }}>VALIDATOR</div>
            <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center" }}>
              <span style={{ color: "#fff", fontWeight: 700 }}>{selected.name}</span>
              <span style={{ color: RISK_COLOR[selected.risk], fontFamily: "monospace", fontWeight: 900 }}>{selected.apr}% APR</span>
            </div>
          </div>

          <div style={{ marginBottom: 16 }}>
            <div style={{ fontSize: 11, color: "#555", fontFamily: "monospace", marginBottom: 6 }}>AMOUNT (BTC)</div>
            <input
              type="number" value={amount} onChange={e => setAmount(e.target.value)}
              placeholder="0.0000"
              style={{
                width: "100%", padding: "10px 14px", borderRadius: 6, fontSize: 15,
                background: "#0a0a0a", border: "1px solid #2a2a2a", color: "#fff",
                fontFamily: "monospace", outline: "none", boxSizing: "border-box",
              }}
            />
          </div>

          <div style={{ marginBottom: 20 }}>
            <div style={{ fontSize: 11, color: "#555", fontFamily: "monospace", marginBottom: 6 }}>
              LOCK PERIOD — <span style={{ color: "#f97316" }}>{lockDays} days</span>
              <span style={{ color: "#333", marginLeft: 8 }}>(min: {selected.minLock}d)</span>
            </div>
            <input
              type="range" min={selected.minLock} max={180} value={lockDays}
              onChange={e => setLockDays(parseInt(e.target.value))}
              style={{ width: "100%", accentColor: "#f97316" }}
            />
            <div style={{ display: "flex", justifyContent: "space-between", fontSize: 10, color: "#444", fontFamily: "monospace" }}>
              <span>{selected.minLock}d min</span><span>180d max</span>
            </div>
          </div>

          <div style={{
            padding: "12px 16px", borderRadius: 8, background: "#0a0a0a",
            border: "1px solid #1e1e1e", marginBottom: 16,
          }}>
            <div style={{ display: "flex", justifyContent: "space-between", fontSize: 12, fontFamily: "monospace", marginBottom: 6 }}>
              <span style={{ color: "#555" }}>Est. rewards</span>
              <span style={{ color: "#22c55e", fontWeight: 700 }}>{estRewards} BTC</span>
            </div>

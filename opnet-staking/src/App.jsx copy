// ── Helpers ──────────────────────────────────────────────────────────────────
function calcHealthScore(positions) {
  if (!positions.length) return 0;
  const validators = new Set(positions.map(p => p.validatorId));
  const diversification = Math.min(validators.size / 3, 1) * 40;
  const avgUptime = positions.reduce((acc, p) => {
    const v = VALIDATORS.find(v => v.id === p.validatorId);
    return acc + (v?.uptime ?? 95);
  }, 0) / positions.length;
  const uptimeScore = ((avgUptime - 90) / 10) * 40;
  const avgRisk = positions.reduce((acc, p) => {
    const r = { safe: 0, mid: 1, degen: 2 }[VALIDATORS.find(v => v.id === p.validatorId)?.risk ?? "mid"];
    return acc + r;
  }, 0) / positions.length;
  const riskScore = (1 - avgRisk / 2) * 20;
  return Math.round(Math.max(0, Math.min(100, diversification + uptimeScore + riskScore)));
}

function formatCountdown(ms) {
  if (ms <= 0) return "UNLOCKED";
  const s = Math.floor(ms / 1000);
  const d = Math.floor(s / 86400);
  const h = Math.floor((s % 86400) / 3600);
  const m = Math.floor((s % 3600) / 60);
  const sec = s % 60;
  if (d > 0) return `${d}d ${h}h ${m}m`;
  return `${h.toString().padStart(2,"0")}:${m.toString().padStart(2,"0")}:${sec.toString().padStart(2,"0")}`;
}

function fakeTxHash() {
  return "0x" + [...Array(64)].map(() => Math.floor(Math.random()*16).toString(16)).join("");
}


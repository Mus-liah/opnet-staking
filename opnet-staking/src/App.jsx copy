  const [connected, setConnected] = useState(false);
  const [tab, setTab] = useState("stake");
  const [selectedValidator, setSelectedValidator] = useState(null);
  const [positions, setPositions] = useState(initialPositions);
  const [now, setNow] = useState(Date.now());

  useEffect(() => {
    const t = setInterval(() => setNow(Date.now()), 1000);
    return () => clearInterval(t);
  }, []);

  const totalStaked = positions.reduce((a, p) => a + p.staked, 0);
  const totalRewards = positions.reduce((a, p) => a + p.rewards + (p.staked * p.apr / 100 / 365 / 86400) * ((now - p.startTs) / 1000), 0);
  const health = calcHealthScore(positions);

  const handleStaked = (pos) => {
    setPositions(prev => [...prev, pos]);
    setTab("positions");
  };

  const handleClaim = (id) => {
    setPositions(prev => prev.map(p => p.id === id ? { ...p, rewards: 0, claimed: true } : p));
  };

  return (
    <div style={{ minHeight: "100vh", background: "#070707", color: "#fff", fontFamily: "'Segoe UI', system-ui, sans-serif" }}>
      <WalletBar connected={connected} onConnect={() => setConnected(c => !c)} />

      <div style={{ maxWidth: 1100, margin: "0 auto", padding: "28px 20px" }}>

        {/* Portfolio stats */}
        <div style={{ display: "flex", gap: 14, marginBottom: 24, flexWrap: "wrap" }}>
          <StatCard label="TOTAL STAKED" value={`${totalStaked.toLocaleString()} BTC`} sub="across all positions" accent="#f97316" />
          <StatCard label="TOTAL REWARDS" value={`${totalRewards.toFixed(6)} BTC`} sub="live accruing ↑" accent="#22c55e" />
          <StatCard label="ACTIVE POSITIONS" value={positions.length} sub={`${VALIDATORS.length} validators available`} accent="#8b5cf6" />
          <HealthGauge score={health} />
        </div>

        {/* Tabs */}
        <div style={{ display: "flex", gap: 2, marginBottom: 20, background: "#0a0a0a", borderRadius: 8, padding: 4, width: "fit-content", border: "1px solid #1a1a1a" }}>
          {[["stake", "⚡ Stake"], ["positions", `📊 Positions (${positions.length})`]].map(([key, label]) => (
            <button key={key} onClick={() => setTab(key)} style={{
              padding: "8px 20px", borderRadius: 6, fontWeight: 700, fontSize: 13,
              cursor: "pointer", fontFamily: "monospace", border: "none",
              background: tab === key ? "#f97316" : "transparent",
              color: tab === key ? "#000" : "#555",
              transition: "all 0.2s",
            }}>{label}</button>
          ))}
        </div>

        {/* Stake Tab */}
        {tab === "stake" && (
          <div style={{ display: "grid", gridTemplateColumns: "1fr 320px", gap: 16, alignItems: "start" }}>
            <div style={{ display: "flex", flexDirection: "column", gap: 16 }}>
              <APRChart onSelect={setSelectedValidator} selected={selectedValidator} />
              <ValidatorTable onSelect={setSelectedValidator} selected={selectedValidator} />
            </div>
            <StakePanel selected={selectedValidator} onStaked={handleStaked} />
          </div>
        )}

        {/* Positions Tab */}
        {tab === "positions" && (
          <div>
            {positions.length === 0 ? (
              <div style={{ textAlign: "center", padding: "60px 0", color: "#333", fontFamily: "monospace" }}>
                No active positions. Go stake something, degen.
              </div>
            ) : (
              <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(300px, 1fr))", gap: 14 }}>
                {positions.map(pos => (
                  <PositionCard key={pos.id} pos={pos} now={now} onClaim={handleClaim} />
                ))}
              </div>
            )}
            {positions.length > 0 && (
              <button onClick={() => {
                const all = positions.reduce((a, p) => a + p.rewards + (p.staked * p.apr / 100 / 365 / 86400) * ((now - p.startTs) / 1000), 0);
                alert(`Claiming all rewards: ${all.toFixed(6)} BTC\nTX: ${fakeTxHash()}`);
              }} style={{
                marginTop: 20, padding: "12px 28px", borderRadius: 8, fontWeight: 900,
                fontSize: 14, fontFamily: "monospace", cursor: "pointer",
                background: "#0f1f0f", color: "#22c55e", border: "1px solid #22c55e44",
              }}>
                ⚡ CLAIM ALL REWARDS ({totalRewards.toFixed(4)} BTC)
              </button>
            )}
          </div>
        )}
      </div>
    </div>
  );
}

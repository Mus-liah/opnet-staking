  );
}

function PositionCard({ pos, now, onClaim }) {
  const [claimed, setClaimed] = useState(false);
  const [claiming, setClaiming] = useState(false);
  const remaining = pos.unlockTs - now;
  const elapsed = now - pos.startTs;
  const total = pos.unlockTs - pos.startTs;
  const progress = Math.min((elapsed / total) * 100, 100);
  const liveRewards = pos.rewards + (pos.staked * pos.apr / 100 / 365 / 86400) * (elapsed / 1000);

  const handleClaim = () => {
    setClaiming(true);
    setTimeout(() => { setClaimed(true); setClaiming(false); onClaim(pos.id); }, 1500);
  };

  return (
    <div style={{
      padding: "20px", borderRadius: 10, background: "#0e0e0e",
      border: `1px solid ${remaining <= 0 ? "#22c55e44" : "#1a1a1a"}`,
      boxShadow: remaining <= 0 ? "0 0 20px #22c55e11" : "none",
    }}>
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: 14 }}>
        <div>
          <div style={{ fontWeight: 700, color: "#ddd", fontSize: 15 }}>{pos.validator}</div>
          <div style={{ fontSize: 11, color: "#555", fontFamily: "monospace", marginTop: 2 }}>
            {RISK_LABEL[VALIDATORS.find(v => v.id === pos.validatorId)?.risk ?? "mid"]}
          </div>
        </div>
        <div style={{ textAlign: "right" }}>
          <div style={{ fontWeight: 900, color: "#f97316", fontFamily: "monospace", fontSize: 18 }}>{pos.apr}%</div>
          <div style={{ fontSize: 10, color: "#555" }}>APR</div>
        </div>
      </div>

      <div style={{ display: "flex", gap: 16, marginBottom: 14 }}>
        <div>
          <div style={{ fontSize: 10, color: "#555", fontFamily: "monospace" }}>STAKED</div>
          <div style={{ color: "#fff", fontWeight: 700, fontFamily: "monospace" }}>{pos.staked.toLocaleString()} BTC</div>
        </div>
        <div>
          <div style={{ fontSize: 10, color: "#555", fontFamily: "monospace" }}>REWARDS</div>
          <div style={{ color: "#22c55e", fontWeight: 700, fontFamily: "monospace" }}>{liveRewards.toFixed(6)} BTC</div>
        </div>
      </div>

      {/* Lock timer */}
      <div style={{ marginBottom: 14 }}>
        <div style={{ display: "flex", justifyContent: "space-between", fontSize: 10, color: "#555", fontFamily: "monospace", marginBottom: 6 }}>
          <span>LOCK PROGRESS</span>
          <span style={{ color: remaining <= 0 ? "#22c55e" : "#f59e0b", fontWeight: 700 }}>
            {formatCountdown(remaining)}
          </span>
        </div>
        <div style={{ height: 4, borderRadius: 2, background: "#1a1a1a", overflow: "hidden" }}>
          <div style={{
            width: `${progress}%`, height: "100%", borderRadius: 2,
            background: remaining <= 0 ? "#22c55e" : "#f97316",
            transition: "width 1s",
          }} />
        </div>
      </div>

      {claimed ? (
        <div style={{ padding: "8px 12px", borderRadius: 6, background: "#0a1a0a", border: "1px solid #22c55e44", fontFamily: "monospace", fontSize: 11, color: "#22c55e", textAlign: "center" }}>
          ✓ Rewards claimed
        </div>
      ) : (
        <button onClick={handleClaim} disabled={claiming} style={{
          width: "100%", padding: "9px", borderRadius: 6, fontWeight: 700,
          fontSize: 12, fontFamily: "monospace", cursor: claiming ? "not-allowed" : "pointer",
          background: claiming ? "#111" : "#0f1f0f",
          color: claiming ? "#333" : "#22c55e",
          border: "1px solid #22c55e44", transition: "all 0.2s",
        }}>
          {claiming ? "⏳ Claiming..." : `CLAIM ${liveRewards.toFixed(4)} BTC`}
        </button>
      )}

      {remaining > 0 && (
        <div style={{ marginTop: 8, fontSize: 10, color: "#444", fontFamily: "monospace", textAlign: "center" }}>
          ⚠ Early exit = 15% slash penalty
        </div>
      )}
    </div>
  );
}

// ── Main App ─────────────────────────────────────────────────────────────────
